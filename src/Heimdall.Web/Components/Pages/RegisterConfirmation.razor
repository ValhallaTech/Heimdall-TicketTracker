@page "/register-confirmation"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]

@*
    Server-rendered "check your email" page for the registration flow
    (Phase 1 step 10). Generic copy matches the forgot-password confirmation
    page so neither flow leaks account existence.
*@

<PageTitle>Confirm your email &middot; Heimdall TicketTracker</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5 col-xl-4">
            <div class="card shadow-sm">
                <div class="card-body p-4 p-md-5 text-center">

                    <div class="splash-icon mb-3" aria-hidden="true">
                        <i class="fa-solid fa-envelope-circle-check"></i>
                    </div>
                    <h1 class="h3 fw-bold mb-3">Check your email</h1>
                    <p class="text-body-secondary mb-4">
                        We have sent a confirmation link to your email address.
                        Click the link to activate your account, then sign in.
                    </p>

                    <a href="/login" class="btn btn-primary w-100 py-2">
                        <i class="fa-solid fa-arrow-left me-2" aria-hidden="true"></i>
                        Back to sign in
                    </a>

                </div>
            </div>
        </div>
    </div>
</div>

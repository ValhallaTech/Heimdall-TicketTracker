@page "/admin/memberships"
@attribute [Authorize(Policy = AuthorizationPolicies.SystemAdmin)]
@rendermode InteractiveServer
@using Heimdall.Web.Authorization.Policies
@using Microsoft.AspNetCore.Authorization
@inject ITeamRepository Teams
@inject ITeamMemberRepository TeamMembers

@*
    Phase 2.8 step 25 read-only memberships view. Phase 3.5 (openfga.md §3
    step 9) replaced the inline AdminGate with [Authorize(Policy = SystemAdmin)].
*@

<PageTitle>Memberships — Admin — Heimdall TicketTracker</PageTitle>

<AdminNav Active="memberships" />
<h1 class="h3 fw-semibold mb-3">Team memberships</h1>
<p class="text-body-secondary">Read-only view of every team and its members.</p>

@if (_loading)
{
    <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading…</span></div>
}
else
{
    @foreach (var team in _teams)
    {
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-transparent">
                <strong>@team.Name</strong>
                <span class="text-body-secondary small ms-2">/@team.Slug</span>
            </div>
            <ul class="list-group list-group-flush">
                @if (!_membersByTeam.TryGetValue(team.Id, out var members) || members.Count == 0)
                {
                    <li class="list-group-item text-body-secondary">No members.</li>
                }
                else
                {
                    @foreach (var m in members)
                    {
                        <li class="list-group-item d-flex justify-content-between">
                            <span>@m.UserId</span>
                            <span class="badge text-bg-secondary">@m.Role</span>
                        </li>
                    }
                }
            </ul>
        </div>
    }
}

@code {
    private bool _loading = true;
    private IReadOnlyList<Team> _teams = [];
    private readonly Dictionary<Guid, IReadOnlyList<TeamMember>> _membersByTeam = [];

    protected override async Task OnInitializedAsync()
    {
        _teams = await Teams.GetAllAsync();
        foreach (var team in _teams)
        {
            _membersByTeam[team.Id] = await TeamMembers.GetByParentAsync(team.Id);
        }
        _loading = false;
    }
}

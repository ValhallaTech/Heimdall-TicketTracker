@*
    Phase 2.8 step 25 (docs/proposals/team-collaboration.md §7) — system-admin
    landing page skeleton. Phase 2 ships a minimal read-only view; richer
    create/edit flows land in Phase 3.

    Phase 3.5 (openfga.md §3 step 9) replaced the inline AdminGate with
    [Authorize(Policy = SystemAdmin)] — the policy is served by
    SystemAdminAuthorizationHandler which reads users.system_admin directly
    (no FGA dependency, so it remains usable during a sidecar outage).
*@

@page "/admin/hierarchy"
@attribute [Authorize(Policy = AuthorizationPolicies.SystemAdmin)]
@attribute [Authorize(Policy = AuthorizationPolicies.RequireMfa)]
@rendermode InteractiveServer
@using Heimdall.Web.Authorization.Policies
@using Microsoft.AspNetCore.Authorization
@inject IOrganizationRepository Organizations
@inject ITeamRepository Teams
@inject IProjectRepository Projects

<PageTitle>Hierarchy — Admin — Heimdall TicketTracker</PageTitle>

<AdminNav Active="hierarchy" />
<h1 class="h3 fw-semibold mb-3">Hierarchy</h1>
<p class="text-body-secondary">Organizations, teams, and projects.</p>

@if (_loading)
{
    <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading…</span></div>
}
else if (_orgs.Count == 0)
{
    <p class="text-body-secondary">No organizations yet.</p>
}
else
{
    <ul class="list-group">
        @foreach (var org in _orgs)
        {
            <li class="list-group-item">
                <i class="fa-solid fa-building me-2" aria-hidden="true"></i>
                <strong>@org.Name</strong>
                <span class="text-body-secondary small ms-2">/@org.Slug</span>
                @if (_teamsByOrg.TryGetValue(org.Id, out var teams) && teams.Count > 0)
                {
                    <ul class="ms-4 mt-2">
                        @foreach (var team in teams)
                        {
                            <li>
                                <i class="fa-solid fa-users me-2" aria-hidden="true"></i>
                                @team.Name <span class="text-body-secondary small">/@team.Slug</span>
                                @if (_projectsByTeam.TryGetValue(team.Id, out var projects) && projects.Count > 0)
                                {
                                    <ul class="ms-4">
                                        @foreach (var p in projects)
                                        {
                                            <li>
                                                <i class="fa-solid fa-folder me-2 text-body-secondary" aria-hidden="true"></i>
                                                @p.Name <span class="text-body-secondary small">/@p.Slug</span>
                                            </li>
                                        }
                                    </ul>
                                }
                            </li>
                        }
                    </ul>
                }
            </li>
        }
    </ul>
}

@code {
    private bool _loading = true;
    private IReadOnlyList<Organization> _orgs = [];
    private readonly Dictionary<Guid, IReadOnlyList<Team>> _teamsByOrg = [];
    private readonly Dictionary<Guid, IReadOnlyList<Project>> _projectsByTeam = [];

    protected override async Task OnInitializedAsync()
    {
        _orgs = await Organizations.GetAllAsync();
        foreach (var org in _orgs)
        {
            var teams = await Teams.GetByOrganizationAsync(org.Id);
            _teamsByOrg[org.Id] = teams;
            foreach (var team in teams)
            {
                _projectsByTeam[team.Id] = await Projects.GetByTeamAsync(team.Id);
            }
        }
        _loading = false;
    }
}

@page "/reset-password"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@inject Heimdall.Web.Email.EmailFlowGate Gate

@*
    Server-rendered reset-password page (Phase 1 step 10). Reads ?email=&token=
    from the query (provided by the link emailed to the user) and posts both
    plus a new password to /account/reset-password. SSR-only — credential
    handling MUST run on a fresh HTTP request, not over a SignalR circuit.
*@

<PageTitle>Reset password &middot; Heimdall TicketTracker</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5 col-xl-4">
            <div class="card shadow-sm">
                <div class="card-body p-4 p-md-5">

                    <div class="text-center mb-4">
                        <div class="splash-icon mb-3" aria-hidden="true">
                            <i class="fa-solid fa-shield-halved"></i>
                        </div>
                        <h1 class="h3 fw-bold mb-0">Set a new password</h1>
                    </div>

                    @if (!Gate.IsActive)
                    {
                        <div class="alert alert-info" role="alert">
                            <i class="fa-solid fa-circle-info me-2" aria-hidden="true"></i>
                            Password reset is currently unavailable. Contact your administrator.
                        </div>
                        <a href="/login" class="btn btn-outline-secondary w-100 py-2">
                            <i class="fa-solid fa-arrow-left me-2" aria-hidden="true"></i>
                            Back to sign in
                        </a>
                    }
                    else
                    {
                        @if (HasInvalidToken)
                        {
                            <div class="alert alert-danger" role="alert">
                                <i class="fa-solid fa-triangle-exclamation me-2" aria-hidden="true"></i>
                                The reset link is invalid or has expired. Please request a new one.
                            </div>
                        }
                        else if (HasMismatch)
                        {
                            <div class="alert alert-danger" role="alert">
                                <i class="fa-solid fa-triangle-exclamation me-2" aria-hidden="true"></i>
                                The two passwords did not match. Please try again.
                            </div>
                        }

                        <form method="post" action="/account/reset-password">
                            <AntiforgeryToken />

                            <input type="hidden" name="email" value="@Email" />
                            <input type="hidden" name="token" value="@Token" />

                            <div class="mb-3">
                                <label for="reset-email" class="form-label">Email address</label>
                                <input id="reset-email"
                                       type="email"
                                       class="form-control"
                                       value="@Email"
                                       autocomplete="email"
                                       readonly />
                            </div>

                            <div class="mb-3">
                                <label for="reset-password" class="form-label">New password</label>
                                <input id="reset-password"
                                       name="password"
                                       type="password"
                                       class="form-control"
                                       autocomplete="new-password"
                                       required
                                       aria-invalid="@AriaInvalid" />
                            </div>

                            <div class="mb-3">
                                <label for="reset-password-confirm" class="form-label">Confirm new password</label>
                                <input id="reset-password-confirm"
                                       name="confirmPassword"
                                       type="password"
                                       class="form-control"
                                       autocomplete="new-password"
                                       required
                                       aria-invalid="@AriaInvalid" />
                            </div>

                            <button type="submit" class="btn btn-primary w-100 py-2">
                                <i class="fa-solid fa-key me-2" aria-hidden="true"></i>
                                Reset password
                            </button>
                        </form>

                        <div class="text-center mt-3">
                            <a href="/login" class="small text-decoration-none">Back to sign in</a>
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>
</div>

@code {
    /// <summary>Email address bound from the reset link's query string.</summary>
    [SupplyParameterFromQuery] public string? Email { get; set; }

    /// <summary>Single-use reset token bound from the reset link's query string.</summary>
    [SupplyParameterFromQuery] public string? Token { get; set; }

    /// <summary>
    /// Optional error indicator. <c>"invalid-token"</c> or <c>"passwords-mismatch"</c>
    /// trigger the corresponding alert; any other value is ignored.
    /// </summary>
    [SupplyParameterFromQuery] public string? Error { get; set; }

    private bool HasInvalidToken => string.Equals(Error, "invalid-token", StringComparison.Ordinal);

    private bool HasMismatch => string.Equals(Error, "passwords-mismatch", StringComparison.Ordinal);

    private string? AriaInvalid => (HasInvalidToken || HasMismatch) ? "true" : null;
}

@page "/"
@page "/splash"

<PageTitle>Heimdall TicketTracker</PageTitle>

<div class="splash-hero d-flex flex-column justify-content-center align-items-center text-center px-3">

    <div class="splash-icon mb-4" aria-hidden="true">
        <i class="fa-solid fa-shield-halved"></i>
    </div>

    <h1 class="display-4 fw-bold mb-3">Heimdall TicketTracker</h1>

    <p class="lead text-body-secondary mb-5 splash-tagline">
        The watchful guardian of your work.<br class="d-none d-sm-inline" />
        Track tickets across the Nine Realms.
    </p>

    <a href="/tickets" class="btn btn-primary btn-lg px-5 py-3 splash-cta shadow">
        <i class="fa-solid fa-ticket me-2" aria-hidden="true"></i>
        Open Tickets
    </a>

</div>

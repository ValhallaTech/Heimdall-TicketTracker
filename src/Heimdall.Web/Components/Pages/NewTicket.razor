@page "/tickets/new"
@attribute [Authorize(Policy = AuthorizationPolicies.IsAuthenticated)]
@rendermode InteractiveServer
@using Heimdall.Web.Authorization.Policies
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using Heimdall.Core.Interfaces
@using Heimdall.Web.Bootstrap
@inject ITicketService TicketService
@inject IOrganizationRepository OrganizationRepository
@inject ITeamRepository TeamRepository
@inject IProjectRepository ProjectRepository
@inject ITeamMemberRepository TeamMemberRepository
@inject IUserLookup UserLookup
@inject NavigationManager Navigation

<PageTitle>New Ticket — Heimdall TicketTracker</PageTitle>

<div class="mb-4">
    <a href="/tickets" class="btn btn-link ps-0 text-decoration-none"><i class="fa-solid fa-arrow-left me-1" aria-hidden="true"></i> Back to tickets</a>
</div>

<div class="card shadow-sm mx-auto" style="max-width: 720px;">
    <div class="card-header bg-transparent py-3">
        <h1 class="h4 mb-0 fw-semibold">New Ticket</h1>
    </div>
    <div class="card-body p-4">
        <EditForm Model="Model" OnValidSubmit="SaveAsync" FormName="ticket-form">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger small mb-3" />
            <input type="hidden" name="Model.Id" value="@Model.Id" />

            <fieldset class="row g-3">
                <legend class="col-12 col-form-label fw-medium pb-0 pt-0">Details</legend>

                <div class="col-12">
                    <label for="title" class="form-label">Title</label>
                    <input id="title" name="Model.Title" class="form-control" @bind="Model.Title" placeholder="Short summary of the issue" />
                </div>

                <div class="col-12">
                    <label for="description" class="form-label">Description</label>
                    <textarea id="description" name="Model.Description" class="form-control" rows="5" @bind="Model.Description" placeholder="Detailed description of the issue, steps to reproduce, expected behaviour, etc."></textarea>
                </div>
            </fieldset>

            <hr class="my-3" />

            <fieldset class="row g-3">
                <legend class="col-12 col-form-label fw-medium pb-0 pt-0">Classification</legend>

                <div class="col-md-6">
                    <label for="status" class="form-label">Status</label>
                    <InputSelect id="status" class="form-select" @bind-Value="Model.Status">
                        @foreach (var s in Enum.GetValues<TicketStatus>())
                        {
                            <option value="@s">@s</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-md-6">
                    <label for="priority" class="form-label">Priority</label>
                    <InputSelect id="priority" class="form-select" @bind-Value="Model.Priority">
                        @foreach (var p in Enum.GetValues<TicketPriority>())
                        {
                            <option value="@p">@p</option>
                        }
                    </InputSelect>
                </div>
            </fieldset>

            <hr class="my-3" />

            <fieldset class="row g-3">
                <legend class="col-12 col-form-label fw-medium pb-0 pt-0">Routing</legend>

                <div class="col-md-6">
                    <label for="team" class="form-label">Team</label>
                    <InputSelect id="team"
                                 class="form-select"
                                 Value="Model.TeamId"
                                 ValueExpression="@(() => Model.TeamId)"
                                 ValueChanged="@((Guid v) => OnTeamChangedAsync(v))">
                        <option value="@Guid.Empty" disabled>Select a team…</option>
                        @foreach (var t in _teams)
                        {
                            <option value="@t.Id">@t.Name</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-md-6">
                    <label for="project" class="form-label">Project</label>
                    <InputSelect id="project" class="form-select" @bind-Value="Model.ProjectId">
                        <option value="@Guid.Empty" disabled>Select a project…</option>
                        @foreach (var p in _projects)
                        {
                            <option value="@p.Id">@p.Name</option>
                        }
                    </InputSelect>
                </div>
            </fieldset>

            <hr class="my-3" />

            <fieldset class="row g-3">
                <legend class="col-12 col-form-label fw-medium pb-0 pt-0">People</legend>

                @* Phase 2.8 step 24 — reporter / assignee pickers bound to the      *@
                @* selected team's membership. The id attributes match those used by *@
                @* the Phase 2.5 raw-Guid inputs so existing aria-/test selectors    *@
                @* continue to work; the underlying control is now a <select>.      *@
                <div class="col-md-6">
                    <label for="reporter" class="form-label">Reporter</label>
                    <InputSelect id="reporter" class="form-select" @bind-Value="Model.ReporterId">
                        <option value="@Guid.Empty" disabled>Select a reporter…</option>
                        @foreach (var m in _teamMembers)
                        {
                            <option value="@m.UserId">@(_memberNames.GetValueOrDefault(m.UserId, m.UserId.ToString()))</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-md-6">
                    <label for="assignee" class="form-label">
                        Assignee
                        <span class="text-body-secondary fw-normal">(optional)</span>
                    </label>
                    <InputSelect id="assignee" class="form-select" @bind-Value="Model.AssigneeId">
                        <option value="">Unassigned</option>
                        @foreach (var m in _teamMembers)
                        {
                            <option value="@m.UserId">@(_memberNames.GetValueOrDefault(m.UserId, m.UserId.ToString()))</option>
                        }
                    </InputSelect>
                </div>
            </fieldset>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="fa-solid fa-floppy-disk me-1" aria-hidden="true"></i>Create Ticket
                </button>
                <a href="/tickets" class="btn btn-outline-secondary"><i class="fa-solid fa-xmark me-1" aria-hidden="true"></i> Cancel</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    /// <summary>
    /// Cascaded authentication state — used to default <see cref="TicketDto.ReporterId"/>
    /// to the current user's id so the FK isn't <see cref="Guid.Empty"/> on submission.
    /// </summary>
    [CascadingParameter]
    public Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    /// <summary>
    /// Form-backed model. Marked with <see cref="SupplyParameterFromFormAttribute"/>
    /// so Blazor rehydrates the posted form values on submit when using enhanced
    /// navigation in a .NET 8+ Blazor Web App.
    /// </summary>
    [SupplyParameterFromForm(FormName = "ticket-form")]
    public TicketDto Model { get; set; } = default!;

    // Phase 2.8 step 24 — picker backing data. Loaded from the repositories in
    // OnParametersSetAsync. Lists are intentionally readonly references rebound
    // (not mutated in-place) so Blazor's diffing picks up the change.
    private IReadOnlyList<Team> _teams = [];
    private IReadOnlyList<Project> _projects = [];
    private IReadOnlyList<TeamMember> _teamMembers = [];
    private readonly Dictionary<Guid, string> _memberNames = [];

    protected override void OnInitialized()
    {
        Model ??= new TicketDto();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_teams.Count == 0)
        {
            _teams = await TeamRepository.GetAllAsync();
        }

        if (Model.Id != 0)
        {
            Model = new TicketDto();
        }

        await PopulateNewTicketDefaultsAsync();

        // Ensure the dependent pickers (projects / members) are populated for
        // the currently-selected team.
        if (Model.TeamId != Guid.Empty)
        {
            await ReloadTeamScopedPickersAsync(Model.TeamId);
        }
    }

    /// <summary>
    /// Reloads <see cref="_projects"/> and <see cref="_teamMembers"/> for the given
    /// <paramref name="teamId"/>, and resolves member display names via
    /// <see cref="IUserLookup.GetByIdAsync"/>. Called both on initial load and when
    /// the user changes the team picker.
    /// </summary>
    private async Task ReloadTeamScopedPickersAsync(Guid teamId)
    {
        var projectsTask = ProjectRepository.GetByTeamAsync(teamId);
        var membersTask = TeamMemberRepository.GetByParentAsync(teamId);
        await Task.WhenAll(projectsTask, membersTask);
        _projects = projectsTask.Result;
        _teamMembers = membersTask.Result;

        // Resolve any missing member display names. Failures fall through to a
        // raw-Guid label rather than throwing.
        var missing = _teamMembers
            .Select(m => m.UserId)
            .Where(id => !_memberNames.ContainsKey(id))
            .ToList();
        if (missing.Count > 0)
        {
            var lookups = missing.Select(async id =>
            {
                try
                {
                    var user = await UserLookup.GetByIdAsync(id);
                    return (id, name: user?.Email);
                }
                catch
                {
                    return (id, name: (string?)null);
                }
            });
            foreach (var (id, name) in await Task.WhenAll(lookups))
            {
                if (!string.IsNullOrWhiteSpace(name))
                {
                    _memberNames[id] = name!;
                }
            }
        }
    }

    /// <summary>
    /// Handler for the team-picker. Updates <see cref="TicketDto.TeamId"/>, clears
    /// the dependent project / assignee selection (since the previous values likely
    /// belong to a different team), and reloads the projects + members lists.
    /// </summary>
    private async Task OnTeamChangedAsync(Guid newTeamId)
    {
        Model.TeamId = newTeamId;
        Model.ProjectId = Guid.Empty;
        Model.AssigneeId = null;
        if (newTeamId != Guid.Empty)
        {
            await ReloadTeamScopedPickersAsync(newTeamId);
        }
        else
        {
            _projects = [];
            _teamMembers = [];
        }
    }

    /// <summary>
    /// Pre-fills <see cref="TicketDto.ProjectId"/>, <see cref="TicketDto.TeamId"/>, and
    /// <see cref="TicketDto.ReporterId"/> on a fresh new-ticket form so an unedited submit
    /// doesn't violate the Phase 2.4 / 2.5 FK + NOT NULL constraints with
    /// <see cref="Guid.Empty"/>. Defaults are resolved by the same hard-coded slug
    /// constants that <see cref="DefaultHierarchyBootstrapper"/> creates at startup.
    /// </summary>
    private async Task PopulateNewTicketDefaultsAsync()
    {
        if (Model.ProjectId == Guid.Empty || Model.TeamId == Guid.Empty)
        {
            var org = await OrganizationRepository
                .GetBySlugAsync(DefaultHierarchyBootstrapper.OrganizationSlug);
            if (org is not null && Model.TeamId == Guid.Empty)
            {
                var team = await TeamRepository
                    .GetBySlugAsync(org.Id, DefaultHierarchyBootstrapper.TeamSlug);
                if (team is not null)
                {
                    Model.TeamId = team.Id;

                    if (Model.ProjectId == Guid.Empty)
                    {
                        var project = await ProjectRepository
                            .GetBySlugAsync(team.Id, DefaultHierarchyBootstrapper.ProjectSlug);
                        if (project is not null)
                        {
                            Model.ProjectId = project.Id;
                        }
                    }
                }
            }
        }

        if (Model.ReporterId == Guid.Empty && AuthenticationStateTask is not null)
        {
            var state = await AuthenticationStateTask;
            var userId = state.User.FindFirstValue(ClaimTypes.NameIdentifier);
            if (Guid.TryParse(userId, out var parsed))
            {
                Model.ReporterId = parsed;
            }
        }
    }

    private async Task SaveAsync()
    {
        await TicketService.CreateAsync(Model);
        Navigation.NavigateTo("/tickets");
    }
}

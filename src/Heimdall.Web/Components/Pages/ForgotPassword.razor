@page "/forgot-password"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@inject Heimdall.Web.Email.EmailFlowGate Gate

@*
    Server-rendered forgot-password page (Phase 1 step 10 of
    docs/proposals/security-and-authorization.md §9.3). Posts to
    /account/forgot-password — NOT @rendermode InteractiveServer — so the
    "password-reset" rate-limiter and antiforgery validation both run on the
    HTTP pipeline. When EmailFlowGate is inactive (no SMTP configured), this
    page renders a "currently unavailable" banner and suppresses the form.
*@

<PageTitle>Forgot password &middot; Heimdall TicketTracker</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5 col-xl-4">
            <div class="card shadow-sm">
                <div class="card-body p-4 p-md-5">

                    <div class="text-center mb-4">
                        <div class="splash-icon mb-3" aria-hidden="true">
                            <i class="fa-solid fa-key"></i>
                        </div>
                        <h1 class="h3 fw-bold mb-0">Reset your password</h1>
                    </div>

                    @if (!Gate.IsActive || IsDisabled)
                    {
                        <div class="alert alert-info" role="alert">
                            <i class="fa-solid fa-circle-info me-2" aria-hidden="true"></i>
                            Password reset is currently unavailable. Contact your administrator.
                        </div>
                        <a href="/login" class="btn btn-outline-secondary w-100 py-2">
                            <i class="fa-solid fa-arrow-left me-2" aria-hidden="true"></i>
                            Back to sign in
                        </a>
                    }
                    else
                    {
                        <p class="text-body-secondary small mb-4">
                            Enter your account email and we'll send you a link to reset your password.
                        </p>

                        <form method="post" action="/account/forgot-password">
                            <AntiforgeryToken />

                            <div class="mb-3">
                                <label for="forgot-email" class="form-label">Email address</label>
                                <input id="forgot-email"
                                       name="email"
                                       type="email"
                                       class="form-control"
                                       autocomplete="email"
                                       required />
                            </div>

                            <button type="submit" class="btn btn-primary w-100 py-2">
                                <i class="fa-solid fa-paper-plane me-2" aria-hidden="true"></i>
                                Send reset link
                            </button>
                        </form>

                        <div class="text-center mt-3">
                            <a href="/login" class="small text-decoration-none">Back to sign in</a>
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>
</div>

@code {
    /// <summary>Optional <c>?error=</c> query param. <c>"disabled"</c> renders the unavailable banner.</summary>
    [SupplyParameterFromQuery] public string? Error { get; set; }

    private bool IsDisabled => string.Equals(Error, "disabled", StringComparison.Ordinal);
}

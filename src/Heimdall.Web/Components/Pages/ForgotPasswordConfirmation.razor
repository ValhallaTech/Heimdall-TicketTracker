@page "/forgot-password-confirmation"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]

@*
    Server-rendered "check your email" confirmation page (Phase 1 step 10).
    Generic copy by design — never confirms whether an account existed.
*@

<PageTitle>Check your email &middot; Heimdall TicketTracker</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5 col-xl-4">
            <div class="card shadow-sm">
                <div class="card-body p-4 p-md-5 text-center">

                    <div class="splash-icon mb-3" aria-hidden="true">
                        <i class="fa-solid fa-envelope-open-text"></i>
                    </div>
                    <h1 class="h3 fw-bold mb-3">Check your email</h1>
                    <p class="text-body-secondary mb-4">
                        If an account exists for the email you entered, we have sent a
                        password-reset link. The link will expire shortly — please check
                        your inbox (and spam folder).
                    </p>

                    <a href="/login" class="btn btn-primary w-100 py-2">
                        <i class="fa-solid fa-arrow-left me-2" aria-hidden="true"></i>
                        Back to sign in
                    </a>

                </div>
            </div>
        </div>
    </div>
</div>

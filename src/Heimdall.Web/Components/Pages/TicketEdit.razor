@page "/tickets/new"
@page "/tickets/{Id:int}"
@rendermode InteractiveServer
@using System.Security.Claims
@using Heimdall.Core.Interfaces
@using Heimdall.Web.Bootstrap
@using Microsoft.AspNetCore.Components.Authorization
@inject ITicketService TicketService
@inject IOrganizationRepository OrganizationRepository
@inject ITeamRepository TeamRepository
@inject IProjectRepository ProjectRepository
@inject NavigationManager Navigation

<PageTitle>@(IsNew ? "New Ticket" : "Edit Ticket") — Heimdall TicketTracker</PageTitle>

<div class="mb-4">
    <a href="/tickets" class="btn btn-link ps-0 text-decoration-none"><i class="fa-solid fa-arrow-left me-1" aria-hidden="true"></i> Back to tickets</a>
</div>

<div class="card shadow-sm mx-auto" style="max-width: 720px;">
    <div class="card-header bg-transparent py-3">
        <h1 class="h4 mb-0 fw-semibold">@(IsNew ? "New Ticket" : "Edit Ticket")</h1>
    </div>
    <div class="card-body p-4">
        <EditForm Model="Model" OnValidSubmit="SaveAsync" FormName="ticket-form">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger small mb-3" />
            <input type="hidden" name="Model.Id" value="@Model.Id" />

            <fieldset class="row g-3">
                <legend class="col-12 col-form-label fw-medium pb-0 pt-0">Details</legend>

                <div class="col-12">
                    <label for="title" class="form-label">Title</label>
                    <input id="title" name="Model.Title" class="form-control" @bind="Model.Title" placeholder="Short summary of the issue" />
                </div>

                <div class="col-12">
                    <label for="description" class="form-label">Description</label>
                    <textarea id="description" name="Model.Description" class="form-control" rows="5" @bind="Model.Description" placeholder="Detailed description of the issue, steps to reproduce, expected behaviour, etc."></textarea>
                </div>
            </fieldset>

            <hr class="my-3" />

            <fieldset class="row g-3">
                <legend class="col-12 col-form-label fw-medium pb-0 pt-0">Classification</legend>

                <div class="col-md-6">
                    <label for="status" class="form-label">Status</label>
                    <InputSelect id="status" class="form-select" @bind-Value="Model.Status">
                        @foreach (var s in Enum.GetValues<TicketStatus>())
                        {
                            <option value="@s">@s</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-md-6">
                    <label for="priority" class="form-label">Priority</label>
                    <InputSelect id="priority" class="form-select" @bind-Value="Model.Priority">
                        @foreach (var p in Enum.GetValues<TicketPriority>())
                        {
                            <option value="@p">@p</option>
                        }
                    </InputSelect>
                </div>
            </fieldset>

            <hr class="my-3" />

            <fieldset class="row g-3">
                <legend class="col-12 col-form-label fw-medium pb-0 pt-0">People</legend>

                @* TODO(Phase 2.8 step 24): proper user-picker / display-name resolution. *@
                @* These are raw Guid inputs as a minimum compile-fix after the Phase 2.5  *@
                @* migrations replaced the legacy reporter / assignee free-form text       *@
                @* columns with FK uuid columns. The Frontend Expert will replace these    *@
                @* with a typeahead user-picker bound to the team membership in step 24.   *@
                <div class="col-md-6">
                    <label for="reporter" class="form-label">Reporter (user id)</label>
                    <input id="reporter" name="Model.ReporterId" class="form-control" @bind="Model.ReporterId" placeholder="Reporter user id (UUID)" />
                </div>
                <div class="col-md-6">
                    <label for="assignee" class="form-label">
                        Assignee (user id)
                        <span class="text-body-secondary fw-normal">(optional)</span>
                    </label>
                    <input id="assignee" name="Model.AssigneeId" class="form-control" @bind="Model.AssigneeId" placeholder="Assignee user id (UUID)" />
                </div>
            </fieldset>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="fa-solid fa-floppy-disk me-1" aria-hidden="true"></i>@(IsNew ? "Create Ticket" : "Save Changes")
                </button>
                <a href="/tickets" class="btn btn-outline-secondary"><i class="fa-solid fa-xmark me-1" aria-hidden="true"></i> Cancel</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    /// <summary>Route parameter: ticket id. Null/0 means create.</summary>
    [Parameter] public int? Id { get; set; }

    /// <summary>
    /// Cascaded authentication state — used to default <see cref="TicketDto.ReporterId"/>
    /// to the current user's id on new tickets so the FK isn't <see cref="Guid.Empty"/>.
    /// </summary>
    [CascadingParameter]
    public Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    /// <summary>
    /// Form-backed model. Marked with <see cref="SupplyParameterFromFormAttribute"/>
    /// so Blazor rehydrates the posted form values on submit when using enhanced
    /// navigation in a .NET 8+ Blazor Web App.
    /// </summary>
    [SupplyParameterFromForm(FormName = "ticket-form")]
    public TicketDto Model { get; set; } = default!;

    private bool IsNew => Id is null or 0;

    protected override void OnInitialized()
    {
        Model ??= new TicketDto();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (IsNew)
        {
            if (Model.Id != 0)
            {
                Model = new TicketDto();
            }

            await PopulateNewTicketDefaultsAsync();
            return;
        }

        if (Model.Id != Id!.Value)
        {
            Model = await TicketService.GetByIdAsync(Id!.Value) ?? new TicketDto { Id = Id!.Value };
        }
    }

    /// <summary>
    /// Pre-fills <see cref="TicketDto.ProjectId"/>, <see cref="TicketDto.TeamId"/>, and
    /// <see cref="TicketDto.ReporterId"/> on a fresh new-ticket form so an unedited submit
    /// doesn't violate the Phase 2.4 / 2.5 FK + NOT NULL constraints with
    /// <see cref="Guid.Empty"/>. Defaults are resolved by the same hard-coded slug
    /// constants that <see cref="DefaultHierarchyBootstrapper"/> creates at startup.
    /// </summary>
    /// <remarks>
    /// TODO(Phase 2.8 step 24): replace these defaults with a proper team / project
    /// picker bound to the user's memberships (see
    /// <c>docs/proposals/team-collaboration.md</c> §7).
    /// </remarks>
    private async Task PopulateNewTicketDefaultsAsync()
    {
        if (Model.ProjectId == Guid.Empty || Model.TeamId == Guid.Empty)
        {
            var org = await OrganizationRepository
                .GetBySlugAsync(DefaultHierarchyBootstrapper.OrganizationSlug);
            if (org is not null)
            {
                if (Model.TeamId == Guid.Empty)
                {
                    var team = await TeamRepository
                        .GetBySlugAsync(org.Id, DefaultHierarchyBootstrapper.TeamSlug);
                    if (team is not null)
                    {
                        Model.TeamId = team.Id;

                        if (Model.ProjectId == Guid.Empty)
                        {
                            var project = await ProjectRepository
                                .GetBySlugAsync(team.Id, DefaultHierarchyBootstrapper.ProjectSlug);
                            if (project is not null)
                            {
                                Model.ProjectId = project.Id;
                            }
                        }
                    }
                }
            }
        }

        if (Model.ReporterId == Guid.Empty && AuthenticationStateTask is not null)
        {
            var state = await AuthenticationStateTask;
            var userId = state.User.FindFirstValue(ClaimTypes.NameIdentifier);
            if (Guid.TryParse(userId, out var parsed))
            {
                Model.ReporterId = parsed;
            }
        }
    }

    private async Task SaveAsync()
    {
        if (IsNew)
        {
            await TicketService.CreateAsync(Model);
        }
        else
        {
            await TicketService.UpdateAsync(Model);
        }

        Navigation.NavigateTo("/tickets");
    }
}
